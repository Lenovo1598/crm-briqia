# ═══════════════════════════════════════
# Team Ali CRM — Variables de Entorno
# Copiar a .env.local y completar valores
# ═══════════════════════════════════════

# PostgreSQL (Supabase o local)
# Formato: postgresql://usuario:password@host:puerto/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/team_ali_crm

# JWT Secret (mínimo 32 caracteres, debe ser seguro)
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_secreto_jwt_super_seguro_de_minimo_32_caracteres_2024

# App Configuration
NEXT_PUBLIC_APP_NAME=Team Ali
NODE_ENV=development

# API Base URL (para cliente, si es necesario)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Chatwoot (misma DB Supabase — solo necesitás el inbox_id)
# Para encontrarlo: SELECT id, name FROM inboxes;
CHATWOOT_INBOX_ID=1

# Anthropic (para el demo público /chat)
# Generar en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
